@SpringBootTest
@ActiveProfiles("test")
class JwtServiceTest {

    @Autowired
    private JwtService jwtService;

    private User testUser() {
        return User.builder()
                .id(1L)
                .username("testuser")
                .passwordHash("hashed")
                .role(Role.LISTENER)
                .build();
    }

    @Test
    void generateAccessToken_validToken() {
