localhost {
    # Proxy API calls to Spring Boot (must be before file_server)
    handle /api/* {
        reverse_proxy sonance-server:8080
    }

    # Swagger UI and OpenAPI spec are intentionally not proxied (defense in depth)

    # Serve React static build for everything else
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
