# Musicode — Environment Variables
# Copy this file to .env and adjust values for your setup.
# Docker Compose reads .env automatically from the project root.

# Path to your music library on the host machine.
# Mounted read-only inside the container at /music.
MUSIC_DIR=C:/Users/yourname/Music

# Admin password for the first-run seed user.
# Change this before first startup — the default 'changeme' triggers a warning.
# MUSICODE_ADMIN_PASSWORD=your-secure-password

# JWT signing secret. Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
# MUSICODE_JWT_SECRET=your-random-secret-at-least-32-bytes-long
